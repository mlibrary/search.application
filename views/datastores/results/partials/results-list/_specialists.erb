<div class="specialists">
  <div class="specialists__header">
    <h3 class="h5 specialists__heading">Talk to a Library Specialist</h3>
    <%= link_to(body: "Find more specialists", url: "https://www.lib.umich.edu/research-and-scholarship/help-research/find-specialist", open_in_new: true) %>
  </div>
  <ol class="list__no-style specialists__list" id="specialists__list">
  <% @presenter.specialists.each do |specialist| %>
    <li class="specialists__list--item">
      <img src="<%= specialist.image_url %>" alt="Image of <%= specialist.name %>" class="specialists__list--item-image">
      <div class="content specialists__list--item-content">
        <h4 class="h5"><%= link_to(body: specialist.name, url: "https://www.lib.umich.edu/users/#{specialist[:uniqname]}", open_in_new: true) %></h4>
        <p><%= specialist.title %></p>
        <% if specialist[:phone] && specialist[:phone] != "000-000-0000" %>
          <p><%= link_to(body: specialist.phone, url: "tel:+1-#{specialist.phone}") %></p>
        <% end %>
        <p><%= link_to(body: "#{specialist.uniqname}@umich.edu", url: "mailto:#{specialist.uniqname}@umich.edu") %></p>
      </div>
    </li>
  <% end %>
  </ol>
  <%= erb :"datastores/partials/_toggle", locals: {classes: ["specialists__toggle"], id: "specialists__list", count: 3, postfix: "Library Specialists"} %>
</div>
