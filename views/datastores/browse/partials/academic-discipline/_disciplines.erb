<ul class="list__no-style browse__academic-discipline--sublist">
  <% Array(disciplines).each do |d| %>
    <li class="browse__academic-discipline--sublist-item">
      <%= link_to(body: d.name, url: d.url, classes: ["underline__none"]) %>
      (<%= d.count %>)
      <% if d.respond_to?(:disciplines) && d.disciplines && !d.disciplines.empty? %>
        <%= erb :"datastores/browse/partials/academic-discipline/_disciplines", locals: { disciplines: d.disciplines } %>
      <% end %>
    </li>
  <% end %>
</ul>
