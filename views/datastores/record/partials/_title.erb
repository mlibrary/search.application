<% if position %>
  <span class="strong record__title--position">
    <%= position %>.
  </span>
<% end %>
<span class="record__title--titles">
  <% titles.each do |title| %>
    <span class="record__title--content">
      <% id = "full-record__#{title.css_class}" %>
      <span class="record__<%= title.css_class %>" id="<%= id %>">
        <%= title.text %>
      </span>
      <%= erb :"datastores/partials/_truncate", locals: { id: id, count: 300 } %>
    </span>
  <% end %>
</span>
